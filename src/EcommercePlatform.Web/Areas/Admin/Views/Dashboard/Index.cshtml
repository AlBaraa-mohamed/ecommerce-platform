@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<!-- UPDATED DASHBOARD VERSION 2.0 - If you see this in browser source, the new version is loading -->
<div class="mb-4">
    <h2><i class="bi bi-speedometer2"></i> Dashboard Overview</h2>
    <p class="text-muted">Welcome to your admin dashboard - Updated Version</p>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card border-start border-primary border-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Total Orders</h6>
                        <h2 class="mb-0">@ViewBag.TotalOrders</h2>
                    </div>
                    <div class="text-primary" style="font-size: 2.5rem;">
                        <i class="bi bi-bag"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-start border-warning border-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">New Orders</h6>
                        <h2 class="mb-0">@ViewBag.NewOrders</h2>
                    </div>
                    <div class="text-warning" style="font-size: 2.5rem;">
                        <i class="bi bi-bell"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-start border-success border-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Active Products</h6>
                        <h2 class="mb-0">@ViewBag.TotalProducts</h2>
                    </div>
                    <div class="text-success" style="font-size: 2.5rem;">
                        <i class="bi bi-box-seam"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-start border-info border-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Total Revenue</h6>
                        <h2 class="mb-0">$@(((decimal)ViewBag.TotalRevenue).ToString("N2"))</h2>
                    </div>
                    <div class="text-info" style="font-size: 2.5rem;">
                        <i class="bi bi-currency-dollar"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-clock-history"></i> Recent Orders</h5>
        <a href="/Admin/Order" class="btn btn-sm btn-primary">
            <i class="bi bi-arrow-right"></i> View All Orders
        </a>
    </div>
    <div class="card-body p-0">
        @{
            var recentOrders = (List<EcommercePlatform.Domain.Entities.Order>)ViewBag.RecentOrders;
        }
        @if (recentOrders.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Order #</th>
                            <th>Customer</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th style="width: 100px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in recentOrders)
                        {
                            <tr>
                                <td><strong>@order.OrderNumber</strong></td>
                                <td>@order.CustomerName</td>
                                <td>@order.LineItems.Count</td>
                                <td>$@order.LineItems.Sum(l => l.UnitPrice * l.OrderedQuantity).ToString("N2")</td>
                                <td>
                                    <span class="badge @(order.Status switch {
                                        EcommercePlatform.Domain.Entities.OrderStatus.New => "bg-info",
                                        EcommercePlatform.Domain.Entities.OrderStatus.Processing => "bg-warning",
                                        EcommercePlatform.Domain.Entities.OrderStatus.PartiallyDelivered => "bg-primary",
                                        EcommercePlatform.Domain.Entities.OrderStatus.Delivered => "bg-success",
                                        EcommercePlatform.Domain.Entities.OrderStatus.PartiallyReturned => "bg-warning",
                                        EcommercePlatform.Domain.Entities.OrderStatus.Returned => "bg-secondary",
                                        EcommercePlatform.Domain.Entities.OrderStatus.Cancelled => "bg-danger",
                                        _ => "bg-secondary"
                                    })">
                                        @order.Status
                                    </span>
                                </td>
                                <td>@order.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <a href="/Admin/Order/Details/@order.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                <p class="mt-2">No orders yet</p>
            </div>
        }
    </div>
</div>
