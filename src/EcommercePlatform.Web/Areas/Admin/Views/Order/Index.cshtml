@model List<EcommercePlatform.Domain.Entities.Order>
@{
    ViewData["Title"] = "Orders";
}

<div class="d-flex justify-content-between mb-4">
    <h2><i class="bi bi-bag"></i> Orders</h2>
    <div>
        <a href="/Admin/Order/Create" class="btn btn-primary me-2"><i class="bi bi-plus-circle"></i> New Order</a>
        <a href="/Admin/Order/ExportExcel" class="btn btn-success"><i class="bi bi-file-earmark-excel"></i> Export Excel</a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Order #</th>
                <th>Customer</th>
                <th>Phone</th>
                <th>City</th>
                <th>Items</th>
                <th>Status</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td><strong>@order.OrderNumber</strong></td>
                    <td>@order.CustomerName</td>
                    <td>@order.CustomerPhone</td>
                    <td>@order.ShippingCity</td>
                    <td>@order.LineItems.Count</td>
                    <td>
                        @{
                            var badgeClass = order.Status switch {
                                EcommercePlatform.Domain.Entities.OrderStatus.New => "bg-warning",
                                EcommercePlatform.Domain.Entities.OrderStatus.Processing => "bg-info",
                                EcommercePlatform.Domain.Entities.OrderStatus.Delivered => "bg-success",
                                EcommercePlatform.Domain.Entities.OrderStatus.Cancelled => "bg-danger",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @badgeClass">@order.Status</span>
                    </td>
                    <td>@order.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td>
                        <a href="/Admin/Order/Details/@order.Id" class="btn btn-sm btn-outline-primary">View</a>
                        <a href="/Admin/Order/Label/@order.Id" class="btn btn-sm btn-outline-secondary">Label</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
