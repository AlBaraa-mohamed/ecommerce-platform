@{
    ViewData["Title"] = "Create Order";
}

<h2>Create Order</h2>
<form asp-area="Admin" asp-controller="Order" asp-action="Create" method="post">
    <div class="row">
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header">Customer Info</div>
                <div class="card-body">
                    <div class="mb-2">
                        <label class="form-label">Customer Name *</label>
                        <input name="CustomerName" class="form-control" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Phone *</label>
                        <input name="CustomerPhone" class="form-control" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Email</label>
                        <input name="CustomerEmail" type="email" class="form-control" />
                    </div>
                </div>
            </div>
            <div class="card mb-3">
                <div class="card-header">Shipping</div>
                <div class="card-body">
                    <div class="mb-2">
                        <label class="form-label">Address *</label>
                        <input name="ShippingAddress" class="form-control" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">City *</label>
                        <input name="ShippingCity" class="form-control" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Country *</label>
                        <input name="ShippingCountry" class="form-control" required />
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header">Line Items (Product IDs)</div>
                <div class="card-body" id="lineItems">
                    <div class="row mb-2">
                        <div class="col-8"><input type="number" name="productIds" class="form-control" placeholder="Product ID" required /></div>
                        <div class="col-4"><input type="number" name="quantities" class="form-control" placeholder="Qty" min="1" value="1" required /></div>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="addLine()">+ Add Item</button>
                </div>
            </div>
        </div>
    </div>
    <button type="submit" class="btn btn-primary">Create Order</button>
    <a href="/Admin/Order" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
<script>
function addLine() {
    const container = document.getElementById('lineItems');
    const row = document.createElement('div');
    row.className = 'row mb-2';
    row.innerHTML = '<div class="col-8"><input type="number" name="productIds" class="form-control" placeholder="Product ID" required /></div><div class="col-4"><input type="number" name="quantities" class="form-control" placeholder="Qty" min="1" value="1" required /></div>';
    container.appendChild(row);
}
</script>
}
