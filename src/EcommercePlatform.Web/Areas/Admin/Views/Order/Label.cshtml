@model EcommercePlatform.Domain.Entities.Order
@{
    ViewData["Title"] = $"Label - {Model.OrderNumber}";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Shipping Label - @Model.OrderNumber</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <style>
        @@media print { .no-print { display: none; } }
        .label-box { border: 2px solid #000; padding: 20px; max-width: 600px; margin: 20px auto; }
    </style>
</head>
<body>
    <div class="label-box">
        <div class="row">
            <div class="col-8">
                <h4>SHIPPING LABEL</h4>
                <h5>Order: @Model.OrderNumber</h5>
                <hr />
                <strong>Ship To:</strong>
                <p>
                    @Model.CustomerName<br />
                    @Model.CustomerPhone<br />
                    @Model.ShippingAddress<br />
                    @Model.ShippingCity, @Model.ShippingState @Model.ShippingPostalCode<br />
                    @Model.ShippingCountry
                </p>
                <strong>Items:</strong>
                <ul>
                    @foreach (var line in Model.LineItems)
                    {
                        <li>@line.ProductNameSnapshot - Qty: @line.OrderedQuantity</li>
                    }
                </ul>
            </div>
            <div class="col-4 text-center">
                @if (ViewBag.QRCodeBase64 != null)
                {
                    <img src="data:image/png;base64,@ViewBag.QRCodeBase64" class="img-fluid" alt="QR Code" />
                    <br /><small>@Model.OrderNumber</small>
                }
            </div>
        </div>
    </div>
    <div class="text-center no-print mt-3">
        <button onclick="window.print()" class="btn btn-primary">Print Label</button>
        <a href="/Admin/Order/Details/@Model.Id" class="btn btn-secondary ms-2">Back</a>
    </div>
</body>
</html>
