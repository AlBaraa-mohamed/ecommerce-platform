@model EcommercePlatform.Domain.Entities.Product
@{
    ViewData["Title"] = "Edit Product";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-4">
    <h2><i class="bi bi-pencil"></i> Edit Product</h2>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Products</a></li>
            <li class="breadcrumb-item active">Edit: @Model.Name</li>
        </ol>
    </nav>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Product Name <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">SKU <span class="text-danger">*</span></label>
                            <input asp-for="SKU" class="form-control" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Price ($) <span class="text-danger">*</span></label>
                            <input asp-for="Price" type="number" step="0.01" class="form-control" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Stock Quantity</label>
                            <input value="@Model.OnHand" type="number" class="form-control" readonly />
                            <small class="text-muted">Manage via <a asp-controller="Inventory" asp-action="Index">Inventory</a></small>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Status</label>
                            <select asp-for="IsActive" class="form-select">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Product Type <span class="text-danger">*</span></label>
                            <select asp-for="Type" class="form-select" onchange="toggleSizeField(this.value)">
                                <option value="0">General</option>
                                <option value="1">Clothing</option>
                                <option value="2">Shoes</option>
                                <option value="3">Electronics</option>
                                <option value="4">Accessories</option>
                                <option value="5">Books</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3" id="sizeField" style="display: @(Model.Type == EcommercePlatform.Domain.Entities.ProductType.Shoes ? "block" : "none");">
                            <label class="form-label">Shoe Size</label>
                            <select asp-for="Size" class="form-select">
                                <option value="">Select Size</option>
                                @for (int size = 38; size <= 45; size++)
                                {
                                    <option value="@size">@size</option>
                                }
                            </select>
                            <small class="text-muted">EU sizing (38-45)</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Current Image</label>
                        <div class="mb-2">
                            <img src="@(string.IsNullOrEmpty(Model.PrimaryImageUrl) ? "https://placehold.co/200x200/e9ecef/6c757d?text=No+Image" : Model.PrimaryImageUrl)" 
                                 alt="@Model.Name" 
                                 id="currentImage"
                                 class="img-thumbnail" 
                                 style="max-width: 200px;">
                        </div>
                        <label class="form-label">Upload New Image</label>
                        <input type="file" name="imageFile" class="form-control" accept="image/*" 
                               onchange="previewImage(this)" />
                        <small class="text-muted">Leave empty to keep current image</small>
                        <div id="imagePreview" class="mt-2" style="display:none;">
                            <p class="text-muted small">New image preview:</p>
                            <img id="preview" src="" alt="Preview" class="img-thumbnail" style="max-width: 200px;">
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> Update Product
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info">View Details</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card">
            <div class="card-body">
                <h6 class="card-title"><i class="bi bi-graph-up"></i> Quick Stats</h6>
                <table class="table table-sm">
                    <tr>
                        <td>On Hand:</td>
                        <td>@Model.OnHand</td>
                    </tr>
                    <tr>
                        <td>Reserved:</td>
                        <td>@Model.Reserved</td>
                    </tr>
                    <tr>
                        <td>Available:</td>
                        <td>
                            <span class="badge @(Model.Available > 10 ? "bg-success" : Model.Available > 0 ? "bg-warning" : "bg-danger")">
                                @Model.Available
                            </span>
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previewImage(input) {
            const preview = document.getElementById('preview');
            const previewContainer = document.getElementById('imagePreview');

            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    previewContainer.style.display = 'block';
                };
                reader.readAsDataURL(input.files[0]);
            } else {
                previewContainer.style.display = 'none';
            }
        }

        function toggleSizeField(productType) {
            const sizeField = document.getElementById('sizeField');
            // Show size field only for Shoes (value = 2)
            if (productType === '2') {
                sizeField.style.display = 'block';
            } else {
                sizeField.style.display = 'none';
                // Clear size value when hiding
                document.querySelector('select[name="Size"]').value = '';
            }
        }

        // Check initial state on page load
        document.addEventListener('DOMContentLoaded', function() {
            const typeSelect = document.querySelector('select[name="Type"]');
            if (typeSelect) {
                toggleSizeField(typeSelect.value);
            }
        });
    </script>
}
