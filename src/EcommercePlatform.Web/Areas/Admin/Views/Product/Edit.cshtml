@model EcommercePlatform.Domain.Entities.Product
@{
    ViewData["Title"] = "Edit Product";
}

<h2>Edit Product</h2>
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input asp-for="Id" type="hidden" />
            <div class="mb-3">
                <label class="form-label">Name *</label>
                <input asp-for="Name" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">SKU *</label>
                <input asp-for="SKU" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Price *</label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Current Image</label><br />
                <img src="@Model.PrimaryImageUrl" style="max-height:100px" onerror="this.style.display='none'" />
            </div>
            <div class="mb-3">
                <label class="form-label">Upload New Image</label>
                <input type="file" name="imageFile" class="form-control" accept="image/*" />
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label class="form-check-label">Active</label>
            </div>
            <button type="submit" class="btn btn-warning">Save Changes</button>
            <a href="/Admin/Product" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
