@{
    ViewData["Title"] = "Checkout";
    var products = ViewBag.Products as List<EcommercePlatform.Domain.Entities.Product>;
    var cart = ViewBag.Cart as List<CartItem>;
}

<h2>Checkout</h2>
<div class="row">
    <div class="col-md-7">
        <form asp-action="Checkout" method="post">
            <div class="card mb-4">
                <div class="card-header"><h5>Customer Information</h5></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Full Name *</label>
                        <input type="text" name="customerName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Phone *</label>
                        <input type="tel" name="customerPhone" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="customerEmail" class="form-control" />
                    </div>
                </div>
            </div>
            <div class="card mb-4">
                <div class="card-header"><h5>Shipping Address</h5></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Address *</label>
                        <input type="text" name="shippingAddress" class="form-control" required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">City *</label>
                            <input type="text" name="shippingCity" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">State/Province</label>
                            <input type="text" name="shippingState" class="form-control" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Postal Code</label>
                            <input type="text" name="shippingPostalCode" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Country *</label>
                            <input type="text" name="shippingCountry" class="form-control" required />
                        </div>
                    </div>
                </div>
            </div>
            <button type="submit" class="btn btn-success btn-lg w-100"><i class="bi bi-check-circle"></i> Place Order</button>
        </form>
    </div>
    <div class="col-md-5">
        <div class="card">
            <div class="card-header"><h5>Order Summary</h5></div>
            <div class="card-body">
                @if (cart != null && products != null)
                {
                    decimal total = 0;
                    foreach (var item in cart)
                    {
                        var product = products.FirstOrDefault(p => p.Id == item.ProductId);
                        if (product != null)
                        {
                            var lineTotal = product.Price * item.Quantity;
                            total += lineTotal;
                            <div class="d-flex justify-content-between mb-2">
                                <span>@product.Name x@item.Quantity</span>
                                <span>$@lineTotal.ToString("F2")</span>
                            </div>
                        }
                    }
                    <hr />
                    <div class="d-flex justify-content-between fw-bold">
                        <span>Total</span>
                        <span>$@total.ToString("F2")</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
