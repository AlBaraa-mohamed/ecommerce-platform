@model EcommercePlatform.Domain.Entities.Product
@{
    ViewData["Title"] = Model.Name;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Shop</a></li>
        <li class="breadcrumb-item active">@Model.Name</li>
    </ol>
</nav>

<div class="row">
    <div class="col-md-5">
        <img src="@Model.PrimaryImageUrl" class="img-fluid rounded shadow" alt="@Model.Name" onerror="this.src='https://via.placeholder.com/500x500?text=No+Image'">
    </div>
    <div class="col-md-7">
        <h1>@Model.Name</h1>
        <p class="text-muted">SKU: @Model.SKU</p>
        <p>@Model.Description</p>
        <h3 class="text-primary">$@Model.Price.ToString("F2")</h3>
        @if (Model.Available > 0)
        {
            <p class="text-success"><i class="bi bi-check-circle"></i> In Stock (@Model.Available available)</p>
            <form asp-action="AddToCart" asp-controller="Home" method="post" class="d-flex gap-2 align-items-center mt-3">
                <input type="hidden" name="productId" value="@Model.Id" />
                <input type="number" name="quantity" value="1" min="1" max="@Model.Available" class="form-control" style="width:80px" />
                <button type="submit" class="btn btn-primary"><i class="bi bi-cart-plus"></i> Add to Cart</button>
            </form>
        }
        else
        {
            <p class="text-danger"><i class="bi bi-x-circle"></i> Out of Stock</p>
        }
        <a href="/" class="btn btn-outline-secondary mt-3">Back to Shop</a>
    </div>
</div>
